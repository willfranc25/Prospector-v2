# Hermes Pro — Environment Configuration
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://hermes:hermes_secret@localhost:5432/hermes

# Redis
REDIS_URL=redis://localhost:6379

# Apify API Token (required for automated scraping)
# Get yours at https://console.apify.com/account/integrations
APIFY_TOKEN=

# ML Service
ML_SERVICE_URL=http://ml:8000

# API
API_PORT=3001
API_HOST=0.0.0.0

# Web (Vite)
VITE_API_URL=http://localhost:3001

# Optional: Proxy configuration for scraping
# PROXY_URL=http://user:pass@proxy.example.com:8080
